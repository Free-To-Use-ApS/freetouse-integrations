{
  "name": "ftu-canva-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "webpack serve --mode development",
    "build": "webpack --mode production && npm run extract",
    "extract": "formatjs extract \"src/**/*.{ts,tsx}\" --out-file dist/messages_en.json --id-interpolation-pattern '[sha512:contenthash:base64:6]'"
  },
  "dependencies": {
    "@canva/app-hooks": "0.0.0-beta.4",
    "@canva/app-i18n-kit": "^1.2.0",
    "@canva/app-ui-kit": "^5.11.0",
    "@canva/asset": "^2.3.0",
    "@canva/design": "^2.9.0",
    "@canva/intents": "^2.6.0",
    "@canva/platform": "^2.2.2",
    "@formatjs/cli": "^6.14.5",
    "@freetouse/api": "*",
    "@freetouse/style": "*",
    "mobx": "^6.15.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-intl": "^7.1.11"
  },
  "devDependencies": {
    "@formatjs/ts-transformer": "^4.4.7",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "css-loader": "^7.0.0",
    "cssnano": "^7.0.0",
    "postcss-loader": "^8.0.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.7.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^5.0.0"
  }
}
